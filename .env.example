# ---- LatePass environment ----
# Copy to .env.local for local dev, and set the same vars in Vercel for production.

# Public base URL of the app (no trailing slash).
# Local dev: http://localhost:3000
# Production: https://your-app.vercel.app
APP_BASE_URL=http://localhost:3000

# Timezone used for the {date} placeholder and the daily-cap reset.
APP_TIMEZONE=Asia/Kolkata

# Postgres connection string (Supabase or Neon). Use the POOLED/transaction
# connection string for serverless. Must allow SSL.
# Example (Neon):     postgres://user:pass@ep-xxx.neon.tech/dbname?sslmode=require
# Example (Supabase): postgres://postgres.xxx:pass@aws-0-region.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Google OAuth client (from Google Cloud Console > Credentials).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must EXACTLY match an Authorized redirect URI on the OAuth client.
# Local: http://localhost:3000/api/auth/google/callback
# Prod:  https://your-app.vercel.app/api/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# 32-byte key (base64) used to encrypt refresh tokens at rest.
# Generate one with:  npm run keygen
ENCRYPTION_KEY=
